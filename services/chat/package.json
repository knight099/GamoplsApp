{
  "name": "@gamopls/chat",
  "version": "0.0.0",
  "private": true,
  "description": "CHAT module service — mission channel CRUD, message CRUD (media stored as pointer+metadata only), and AlertRaised -> auto-posted system message. Depends only on @gamopls/asset-contracts, @gamopls/event-schemas, @gamopls/event-bus-nats per CLAUDE.md; never imports a concrete plugin and never branches on asset type.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint . --config ../../packages/config/eslint.config.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@gamopls/asset-contracts": "workspace:*",
    "@gamopls/event-bus-nats": "workspace:*",
    "@gamopls/event-schemas": "workspace:*",
    "fastify": "^5.1.0",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@gamopls/config": "workspace:*",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "eslint": "^9.15.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
