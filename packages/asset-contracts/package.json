{
  "name": "@gamopls/asset-contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Asset interfaces (Asset, Locatable, Monitorable, Alertable, Communicable, Taskable) that module services and Asset Type Plugins depend on. No concrete asset types live here.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint . --config ../config/eslint.config.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@gamopls/config": "workspace:*",
    "eslint": "^9.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
