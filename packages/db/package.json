{
  "name": "@gamopls/db",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Prisma database package — single schema for all services against Neon Postgres. Exports a PrismaClient singleton.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "prisma generate && tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint . --config ../../packages/config/eslint.config.mjs",
    "test": "echo 'no tests yet'",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "@gamopls/config": "workspace:*",
    "@types/node": "^20.14.0",
    "eslint": "^9.15.0",
    "prisma": "^6.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
