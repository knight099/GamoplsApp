{
  "name": "@gamopls/event-bus-nats",
  "version": "0.0.0",
  "private": true,
  "description": "The one concrete NATS adapter implementing @gamopls/event-schemas' EventPublisher/EventSubscriber ports. The only package in this repo allowed to depend on `nats`.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint . --config ../config/eslint.config.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@gamopls/event-schemas": "workspace:*",
    "nats": "^2.28.2"
  },
  "devDependencies": {
    "@gamopls/config": "workspace:*",
    "@types/node": "^20.14.0",
    "eslint": "^9.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
