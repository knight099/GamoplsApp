{
  "name": "@gamopls/event-schemas",
  "version": "0.0.0",
  "private": true,
  "description": "zod-validated event payload contracts and transport-agnostic EventPublisher/EventSubscriber ports. Zero transport-lib dependency (DIP) — packages/event-bus-nats is the only concrete adapter.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint . --config ../config/eslint.config.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@gamopls/config": "workspace:*",
    "eslint": "^9.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
