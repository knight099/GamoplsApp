{
  "name": "@gamopls/asset-vehicle",
  "version": "0.0.0",
  "private": true,
  "description": "V1 Asset Type Plugin — implements the shared Asset/Locatable/Monitorable/Alertable/Communicable/Taskable interfaces for vehicles, owns VehicleDetails (trip/plate/fuel data), and self-registers with the plugin registry over HTTP.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "sql"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean",
    "dev": "tsx watch --env-file-if-exists=../../.env src/server.ts",
    "start": "node --env-file-if-exists=../../.env dist/server.js",
    "lint": "eslint . --config ../../packages/config/eslint.config.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@gamopls/asset-contracts": "workspace:*",
    "@gamopls/db": "workspace:*",
    "@gamopls/event-schemas": "workspace:*",
    "fastify": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@gamopls/config": "workspace:*",
    "@types/node": "^20.14.0",
    "eslint": "^9.15.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
