# Postgres / TimescaleDB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gamopls_teamcore
POSTGRES_USER=gamopls
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://gamopls:changeme@localhost:5432/gamopls_teamcore

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# Auth / multi-tenancy (JWT claims: org_id, fleet_id, role)
JWT_SECRET=changeme-dev-only-generate-a-real-secret
JWT_EXPIRES_IN=1h

# apps/web V1 demo login (packages/auth-backed placeholder — NOT real identity,
# see apps/web/lib/demo-login.ts). Replace with Auth0/Clerk before production use.
DEMO_LOGIN_USERNAME=demo
DEMO_LOGIN_PASSWORD=demo
DEMO_LOGIN_ORG_ID=org-demo
DEMO_LOGIN_FLEET_ID=fleet-demo
DEMO_LOGIN_ROLE=fleet_manager

# apps/web gateway (Next.js BFF route handlers) — backend service base URLs.
MAP_SERVICE_URL=http://localhost:4401
CHAT_SERVICE_URL=http://localhost:4300
BOARD_SERVICE_URL=http://localhost:4302
HUB_SERVICE_URL=http://localhost:4500
