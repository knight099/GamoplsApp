# Postgres — Neon serverless. No local Postgres container: this is required,
# not a fallback (infra/docker-compose.yml only runs NATS + MQTT).
DATABASE_URL=postgresql://user:password@your-neon-host/gamopls_teamcore?sslmode=require

# Redis — Upstash REST. Also required, not a fallback — same reasoning as
# DATABASE_URL above.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# NATS
NATS_URL=nats://localhost:4222

# MQTT broker credentials (S-2: anonymous access is disabled at the broker;
# see infra/mosquitto/). core-ingestion subscribes as MQTT_USERNAME (read
# ACL on edgebox/#); the edgebox simulator publishes as MQTT_DEVICE_USERNAME
# (write ACL). Both dev passwords are "changeme-dev-only".
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_USERNAME=core-ingestion
MQTT_PASSWORD=changeme-dev-only
MQTT_DEVICE_USERNAME=edgebox
MQTT_DEVICE_PASSWORD=changeme-dev-only

# Auth / multi-tenancy (JWT claims: org_id, fleet_id, role)
JWT_SECRET=changeme-dev-only-generate-a-real-secret
JWT_EXPIRES_IN=1h

# Shared secret for the gateway-signed internal tenant-scope header
# (x-gamopls-scope). services/board|chat|map verify it and take tenancy
# exclusively from it. Falls back to a dev-only constant outside
# production; REQUIRED in production.
INTERNAL_SCOPE_SECRET=changeme-dev-only-generate-a-real-secret

# Seed inputs for packages/db/prisma/seed.ts (real Prisma-backed login,
# suggestions.md S-5) — running the seed script creates an Org + Fleet +
# User with this email/password so you have something to log in with.
# DEMO_LOGIN_USERNAME may be a bare handle ("demo" -> demo@example.com) or a
# full email ("admin@gamopls.com").
DEMO_LOGIN_USERNAME=demo
DEMO_LOGIN_PASSWORD=demo

# apps/web gateway (Next.js BFF route handlers) — backend service base URLs.
# map/chat/board/hub/fleet/registry are all mounted as route modules on the
# single services/backend process (see services/backend/src/server.ts), so
# these all point at the same host:port with different path prefixes.
# plugins/asset-vehicle stays a genuinely separate deployable (see
# CLAUDE.md's Deployment topology (V1) section), hence its own port.
MAP_SERVICE_URL=http://localhost:4300/map
CHAT_SERVICE_URL=http://localhost:4300/chat
BOARD_SERVICE_URL=http://localhost:4300/board
HUB_SERVICE_URL=http://localhost:4300/hub
FLEET_SERVICE_URL=http://localhost:4300/fleet
REGISTRY_URL=http://localhost:4300/registry
VEHICLE_PLUGIN_URL=http://localhost:4700
